# Copy to .env and adjust for local development.
# Do not commit .env — it is listed in .gitignore.
#
# With Docker Compose, Postgres is available at localhost:5432.
# The api service uses hostname "db" inside the compose network.

DATABASE_URL=postgresql+psycopg://fraud:fraud@localhost:5432/fraud
JWT_SECRET_KEY=dev-only-change-before-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

TIME_WINDOW=1h
BATCH_COUNT=100
LOG_LEVEL=INFO
LOG_FILE=logs/fraud-detector.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
